{
  "name": "zyplux-github",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "tests/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.14",
      "@zyplux/cz": "^0.1.0",
      "@zyplux/eslint-config": "^0.6.1",
      "@zyplux/tsconfig": "^0.1.0",
      "@zyplux/util": "^0.1.1",
      "eslint": "^10.5.0",
      "knip": "^6.20.0",
      "npm-check-updates": "^22.2.7",
      "prettier": "^3.8.4",
      "typescript": "^6.0.3",
      "vitest": "^4.1.9",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "knip": "knip",
    "format": "prettier --write --cache --log-level warn .",
    "typecheck": "tsc -b",
    "lint": "eslint . --cache",
    "lint:fix": "bun run lint --fix",
    "test": "vitest run --passWithNoTests",
    "upgrade": "npm-check-updates --format group",
    "cz": "cz"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@zyplux/cz": "catalog:",
    "@zyplux/eslint-config": "catalog:",
    "@zyplux/tsconfig": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
